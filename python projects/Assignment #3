{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyMZPixwhWBYKIkh6fzbBptX"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["#All steps Assignment #3   (Its assignment 2 but the pdf file is named as assignment 3 so I use)\n","\n","import numpy as np\n","from sklearn.datasets import load_iris  # Importing the Iris dataset from scikit-learn\n","from sklearn.model_selection import train_test_split  # Importing train_test_split function\n","from sklearn.metrics import accuracy_score, precision_score, recall_score  # Importing metrics functions\n","from sklearn.neighbors import KNeighborsClassifier  # Importing KNN classifier\n","from sklearn.model_selection import cross_val_score, GridSearchCV  # Importing cross-validation functions\n","\n","# Step 1: Load a Dataset\n","iris_data = load_iris()  # Loading the Iris dataset\n","features, labels = iris_data.data, iris_data.target  # Extracting features and labels\n","\n","# Display dataset description and basic statistics\n","print(f\"Dataset Description:\\n{iris_data.DESCR}\\nNumber of Instances: {features.shape[0]}, Number of Features: {features.shape[1]}, Number of Classes: {len(iris_data.target_names)}\")\n","\n","# Step 2: Split the Dataset\n","X_train, X_test, y_train, y_test = train_test_split(features, labels, test_size=0.2, random_state=42)  # Splitting the dataset\n","\n","# Printing sizes of training and test sets\n","print(f\"Training Set Size: {X_train.shape[0]}, Test Set Size: {X_test.shape[0]}\")\n","\n","# Step 3: Implement a K-Nearest Neighbors Classifier\n","class KNearestNeighbors:\n","    def __init__(self, k=3):\n","        self.k = k  # Initializing the number of neighbors\n","\n","    def fit(self, X_train, y_train):\n","        self.X_train = X_train  # Storing the training features\n","        self.y_train = y_train  # Storing the training labels\n","\n","    def predict(self, X_test):\n","        y_pred = []  # Initializing list to store predicted labels\n","        for x in X_test:\n","            distances = [np.sqrt(np.sum((x - x_train)**2)) for x_train in self.X_train]  # Calculating distances to all training instances\n","            k_indices = np.argsort(distances)[:self.k]  # Finding indices of k nearest neighbors\n","            k_nearest_labels = [self.y_train[i] for i in k_indices]  # Extracting labels of k nearest neighbors\n","            y_pred.append(max(set(k_nearest_labels), key=k_nearest_labels.count))  # Predicting the label based on majority voting\n","        return np.array(y_pred)  # Returning predicted labels as numpy array\n","\n","# Initialize KNN classifier with k=3\n","knn_model = KNearestNeighbors(k=3)\n","knn_model.fit(X_train, y_train)  # Training the KNN classifier on the training set\n","\n","# Step 4: Perform 5-Fold Cross-Validation on Training set\n","def perform_cross_validation(X_train, y_train, classifier, k=5):\n","    fold_size = len(X_train) // k  # Calculating size of each fold\n","    accuracies = []  # Initializing list to store accuracies\n","\n","    for fold_idx in range(k):  # Iterating over each fold\n","        start_idx = fold_idx * fold_size  # Calculating starting index of current fold\n","        end_idx = (fold_idx + 1) * fold_size if fold_idx < k - 1 else len(X_train)  # Calculating ending index of current fold\n","\n","        X_val, y_val = X_train[start_idx:end_idx], y_train[start_idx:end_idx]  # Defining validation set for current fold\n","        X_train_fold = np.concatenate([X_train[:start_idx], X_train[end_idx:]])  # Defining training set for current fold\n","        y_train_fold = np.concatenate([y_train[:start_idx], y_train[end_idx:]])  # Defining training labels for current fold\n","\n","        classifier.fit(X_train_fold, y_train_fold)  # Training the classifier on current training fold\n","        y_pred = classifier.predict(X_val)  # Predicting labels for validation fold\n","\n","        accuracy = np.sum(y_pred == y_val) / len(y_val)  # Calculating accuracy for current fold\n","        accuracies.append(accuracy)  # Appending accuracy to list of accuracies\n","\n","    return np.mean(accuracies)  # Returning average accuracy across all folds\n","\n","# Perform 5-fold cross-validation for the KNN classifier\n","average_accuracy = perform_cross_validation(X_train, y_train, knn_model, k=5)\n","print(f\"Average Cross-Validation Accuracy (5 folds): {average_accuracy:.2f}\")  # Printing average cross-validation accuracy\n","\n","# Step 5: Test set Results\n","y_pred_test = knn_model.predict(X_test)  # Predicting labels for test set\n","test_accuracy = accuracy_score(y_test, y_pred_test)  # Calculating accuracy for test set\n","test_precision = precision_score(y_test, y_pred_test, average='macro')  # Calculating precision for test set\n","test_recall = recall_score(y_test, y_pred_test, average='macro')  # Calculating recall for test set\n","\n","# Printing evaluation metrics for test set\n","print(f\"Test Set Accuracy: {test_accuracy:.2f}\")\n","print(f\"Test Set Precision: {test_precision:.2f}\")\n","print(f\"Test Set Recall: {test_recall:.2f}\")\n","\n","# Step 6: Comparison Using Scikit-Learn\n","knn_sklearn_model = KNeighborsClassifier(n_neighbors=3)  # Initializing KNN classifier from scikit-learn\n","cv_scores = cross_val_score(knn_sklearn_model, X_train, y_train, cv=5)  # Performing 5-fold cross-validation using scikit-learn\n","average_cv_accuracy = np.mean(cv_scores)  # Calculating average cross-validation accuracy using scikit-learn\n","print(f\"Average Cross-Validation Accuracy (Scikit-Learn): {average_cv_accuracy:.2f}\")  # Printing average cross-validation accuracy\n","\n","# Step 7: Hyperparameter optimization\n","param_grid = {'n_neighbors': np.arange(1, 10, 2)}  # Defining parameter grid for grid search\n","grid_search = GridSearchCV(KNeighborsClassifier(), param_grid, cv=10, scoring='accuracy')  # Initializing grid search with 10-fold cross-validation\n","grid_search.fit(features, labels)  # Performing grid search to find optimal hyperparameters\n","\n","# Printing hyperparameter optimization results\n","print(\"\\nHyperparameter Optimization Results:\")\n","print(f\"Best k: {grid_search.best_params_['n_neighbors']}\")  # Printing best k found by grid search\n","print(f\"Best Cross-Validation Accuracy: {grid_search.best_score_:.2f}\")  # Printing best cross-validation accuracy found by grid search\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"knzmFfpugagt","executionInfo":{"status":"ok","timestamp":1720931437904,"user_tz":300,"elapsed":520,"user":{"displayName":"Basit Hussain","userId":"00253640594032612857"}},"outputId":"1bfc7dbf-cd39-4d01-eba1-2de83a56d0d2"},"execution_count":25,"outputs":[{"output_type":"stream","name":"stdout","text":["Dataset Description:\n",".. _iris_dataset:\n","\n","Iris plants dataset\n","--------------------\n","\n","**Data Set Characteristics:**\n","\n","    :Number of Instances: 150 (50 in each of three classes)\n","    :Number of Attributes: 4 numeric, predictive attributes and the class\n","    :Attribute Information:\n","        - sepal length in cm\n","        - sepal width in cm\n","        - petal length in cm\n","        - petal width in cm\n","        - class:\n","                - Iris-Setosa\n","                - Iris-Versicolour\n","                - Iris-Virginica\n","                \n","    :Summary Statistics:\n","\n","    ============== ==== ==== ======= ===== ====================\n","                    Min  Max   Mean    SD   Class Correlation\n","    ============== ==== ==== ======= ===== ====================\n","    sepal length:   4.3  7.9   5.84   0.83    0.7826\n","    sepal width:    2.0  4.4   3.05   0.43   -0.4194\n","    petal length:   1.0  6.9   3.76   1.76    0.9490  (high!)\n","    petal width:    0.1  2.5   1.20   0.76    0.9565  (high!)\n","    ============== ==== ==== ======= ===== =========