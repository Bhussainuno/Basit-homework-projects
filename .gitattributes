# Ignore generated Java documentation / HTML docs from GitHub language stats
*.html linguist-generated=true
*.css linguist-generated=true
*.js linguist-generated=true
**/*.html linguist-generated=true
**/*.css linguist-generated=true
**/*.js linguist-generated=true

# JavaDoc / generated documentation folders
**/doc/** linguist-generated=true
**/DOCS/** linguist-generated=true
**/foldername/** linguist-generated=true
**/index-files/** linguist-generated=true
**/resources/** linguist-generated=true
**/jquery/** linguist-vendored=true

# Common generated JavaDoc files
